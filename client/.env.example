# Copy to .env.local for development:  cp .env.example .env.local
#
# The base URL of the backend API. This is the ONLY thing that differs between
# local and production.
#   - Local:      http://localhost:8000/api   (the FastAPI container)
#   - Production: https://your-domain-or-ip/api  (served behind Caddy on Vultr)
#
# NEXT_PUBLIC_ prefix = exposed to the browser (safe: it's just a URL, no secret).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
