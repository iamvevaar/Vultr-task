# Copy this file to `.env` and fill in real values:  cp .env.example .env
# The task requires an .env.example for both services, so we keep this in git.
# The real `.env` (with secrets) is git-ignored and NEVER committed.

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Host is "db" because that's the service name in docker-compose.yml
# (Docker gives each service a hostname equal to its name).
DATABASE_URL=postgresql://vultr:vultr@db:5432/challenge_engine

# --- Auth / JWT ---
# Secret used to sign JWT tokens. In production use a long random string.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# Register with this exact value as "admin_code" to create an admin account.
ADMIN_SIGNUP_CODE=make-me-admin

# --- Engine behaviour ---
# The timezone used to decide "day" boundaries for streaks and weekly resets.
APP_TZ=UTC
# How often the background worker polls the events table (seconds).
WORKER_POLL_SECONDS=2

# Comma-separated browser origins allowed to call the API (CORS).
# In production, set this to your deployed frontend URL.
CORS_ORIGINS=http://localhost:3000
